{
  "name": "helmsmith",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Helmsmith monorepo — AgentX platform + toolbox unified (core / harness / context / memory / skillzkit / web / apps + Java controlplane).",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20",
    "bun": ">=1.3"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:packages": "pnpm -r run test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "sync:skills": "node scripts/sync-skills.mjs",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=main",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "pnpm -r run build && changeset publish",
    "release:plan": "node scripts/detect-changed-packages.mjs",
    "catalog": "pnpm --filter @helmsmith/skillzkit run catalog",
    "harness": "bun harness/harness-cli/src/index.ts",
    "harness:run": "bun harness/harness-cli/src/in-process-run.tsx",
    "agentx-workspace": "bun harness/workspace-cli/src/bin.tsx",
    "skillzkit": "bun skillzkit/skillzkit/src/cli.ts",
    "tui": "pnpm --silent harness tui",
    "verify": "tsx examples/verify-no-leak.ts",
    "host-only": "tsx examples/01-host-only.ts",
    "opencode-only": "tsx examples/02-opencode-host-only.ts",
    "roundtrip": "tsx examples/03-uds-roundtrip.ts",
    "dev:servers": "tsx examples/04-server-trio.ts",
    "dev:propagation-demo": "tsx examples/05-auth-propagation-demo.ts",
    "dev:skill-demo": "tsx examples/06-agent-skill-demo.ts",
    "dev:per-skill-demo": "tsx examples/07-per-skill-demo.ts",
    "dev:submit-demo": "tsx examples/08-job-submit-demo.ts",
    "dev:worker-demo": "tsx examples/09-worker-spawn-demo.ts",
    "dev:events-demo": "tsx examples/10-job-events-demo.ts",
    "dev:orchestrator-demo": "tsx examples/11-orchestrated-pipeline-demo.ts",
    "dev:in-process": "tsx examples/12-in-process-cli-demo.ts",
    "tmux": "scripts/dev-tmux.sh",
    "tmux:down": "tmux kill-session -t ${AGENTX_TMUX_SESSION:-agentx} 2>/dev/null || true",
    "tmux:reset": "scripts/tmux-reset.sh"
  },
  "dependencies": {
    "@helmsmith/agent-adapter": "workspace:*",
    "@helmsmith/agent-adapter-langchain": "workspace:*",
    "@helmsmith/agent-auth": "workspace:*",
    "@helmsmith/edge-context-server": "workspace:*",
    "@helmsmith/edge-memory-server": "workspace:*",
    "@helmsmith/harness": "workspace:*",
    "@helmsmith/harness-core": "workspace:*",
    "@helmsmith/harness-pipeline": "workspace:*",
    "@helmsmith/harness-server": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.7.0",
    "bun": "^1.3.13",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "yaml": "^2.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "bun"
    ],
    "overrides": {
      "react": "19.2.6",
      "react-dom": "19.2.6",
      "commander": "^14.0.3",
      "tsup": "^8.5.1",
      "typescript": "^5.9.3",
      "vitest": "^4.1.5",
      "vite": "^6"
    }
  }
}
