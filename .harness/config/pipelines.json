{
  "version": 1,
  "_note": "Pipeline catalog per prd-workspace-template.md F13 + F17. Each phase declares the agent + model + tools that run it. MVP-1 reads this for display; MVP-3+ feeds it to the LangGraph compiler.",
  "pipelines": [
    {
      "id": "feature-add",
      "name": "Generic feature add",
      "description": "Default catch-all when the request doesn't match a more specialized pipeline.",
      "phases": [
        {
          "id": "plan",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "reasoningEffort": "medium",
          "description": "Senior engineer plans the implementation against context",
          "tools": ["memory.query", "context.query"]
        },
        {
          "id": "implement",
          "agent": "opencode-cli",
          "model": "anthropic/claude-opus-4-7",
          "description": "Editor agent makes the changes across product repos",
          "tools": ["memory.put", "context.query", "edit", "bash"]
        },
        {
          "id": "test",
          "agent": "opencode-cli",
          "model": "anthropic/claude-opus-4-7",
          "description": "Run the test suite, fix obvious failures",
          "tools": ["bash"]
        },
        {
          "id": "review",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "reasoningEffort": "high",
          "description": "Review for correctness, naming, edge cases",
          "tools": ["memory.query", "context.query"]
        }
      ]
    },
    {
      "id": "prd-greenfield",
      "name": "PRD greenfield",
      "description": "Write a product spec from scratch. Heavy HITL, no filesystem snapshots.",
      "phases": [
        {
          "id": "intake",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "description": "Clarify the ask, gather constraints",
          "tools": ["memory.query"]
        },
        {
          "id": "research",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "reasoningEffort": "high",
          "description": "Pull related prior PRDs + market context",
          "tools": ["memory.query", "context.query"]
        },
        {
          "id": "draft",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "description": "Write the first PRD draft",
          "tools": ["memory.put"]
        },
        {
          "id": "review",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "reasoningEffort": "high",
          "description": "Critique the draft as the PM/eng/design lens",
          "tools": ["memory.query"]
        },
        {
          "id": "polish",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "description": "Final pass on language, formatting, links",
          "tools": []
        }
      ]
    },
    {
      "id": "brownfield-ui-enhancement",
      "name": "Brownfield UI enhancement",
      "description": "UI-only changes against an existing app. Snapshots per phase; figma context.",
      "phases": [
        {
          "id": "plan",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "tools": ["memory.query", "context.query"]
        },
        {
          "id": "implement",
          "agent": "opencode-cli",
          "model": "anthropic/claude-opus-4-7",
          "tools": ["memory.put", "context.query", "edit", "bash"]
        },
        {
          "id": "test",
          "agent": "opencode-cli",
          "model": "anthropic/claude-opus-4-7",
          "tools": ["bash"]
        },
        {
          "id": "review",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "reasoningEffort": "high",
          "tools": ["memory.query", "context.query"]
        }
      ]
    },
    {
      "id": "brownfield-fullstack-change",
      "name": "Brownfield fullstack change",
      "description": "Cross-cutting feature touching frontend + backend; integration tests gate the merge.",
      "phases": [
        {
          "id": "plan",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "reasoningEffort": "high",
          "tools": ["memory.query", "context.query"]
        },
        {
          "id": "frontend",
          "agent": "opencode-cli",
          "model": "anthropic/claude-opus-4-7",
          "tools": ["memory.put", "context.query", "edit", "bash"]
        },
        {
          "id": "backend",
          "agent": "opencode-cli",
          "model": "anthropic/claude-opus-4-7",
          "tools": ["memory.put", "context.query", "edit", "bash"]
        },
        {
          "id": "integrate",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "tools": ["memory.query", "context.query"]
        },
        {
          "id": "test",
          "agent": "opencode-cli",
          "model": "anthropic/claude-opus-4-7",
          "tools": ["bash"]
        },
        {
          "id": "review",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "reasoningEffort": "high",
          "tools": ["memory.query", "context.query"]
        }
      ]
    },
    {
      "id": "frontend-techstack-upgrade",
      "name": "Frontend tech-stack upgrade",
      "description": "Codemod-heavy migration (e.g. React 18→19, Vue 2→3). Always-snapshot.",
      "phases": [
        {
          "id": "audit",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "reasoningEffort": "high",
          "description": "Inventory current usage of deprecated APIs",
          "tools": ["context.query"]
        },
        {
          "id": "codemod",
          "agent": "opencode-cli",
          "model": "anthropic/claude-opus-4-7",
          "description": "Apply codemod transforms repo-wide",
          "tools": ["edit", "bash"]
        },
        {
          "id": "test",
          "agent": "opencode-cli",
          "model": "anthropic/claude-opus-4-7",
          "tools": ["bash"]
        },
        {
          "id": "review",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "tools": ["memory.query", "context.query"]
        }
      ]
    },
    {
      "id": "backend-techstack-upgrade",
      "name": "Backend tech-stack upgrade",
      "description": "Spring/Java/Node major upgrades; explicit security-fix phase.",
      "phases": [
        {
          "id": "audit",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "reasoningEffort": "high",
          "tools": ["context.query"]
        },
        {
          "id": "migrate",
          "agent": "opencode-cli",
          "model": "anthropic/claude-opus-4-7",
          "tools": ["edit", "bash"]
        },
        {
          "id": "security-fix",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "reasoningEffort": "high",
          "description": "Audit + patch known CVEs in the new stack",
          "tools": ["context.query", "memory.query"]
        },
        {
          "id": "test",
          "agent": "opencode-cli",
          "model": "anthropic/claude-opus-4-7",
          "tools": ["bash"]
        },
        {
          "id": "review",
          "agent": "claude-sdk",
          "model": "claude-opus-4-7",
          "tools": ["memory.query", "context.query"]
        }
