                  "id": "color-picker-area",
                  "type": "frame",
                  "width": "fill_container",
                  "height": 120,
                  "cornerRadius": "$grids:radius.md",
                  "fill": {
                    "type": "gradient",
                    "gradientType": "linear",
                    "rotation": 90,
                    "colors": [
