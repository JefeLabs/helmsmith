                  "height": 12,
                  "cornerRadius": 9999,
                  "fill": {
                    "type": "gradient",
                    "gradientType": "linear",
                    "rotation": 90,
                    "colors": [
                      {
                        "color": "#ff0000",
                        "position": 0
                      },
                      {
                        "color": "#00ff00",
                        "position": 0.5
                      },
                      {
                        "color": "#0000ff",
                        "position": 1
