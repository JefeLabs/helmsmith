{
  "version": "2.11",
  "imports": {
    "colors": "../foundations/colors.lib.pen",
    "type": "../foundations/typography.lib.pen",
    "grids": "../foundations/grids.lib.pen"
  },
  "children": [
    {
      "id": "core-colors",
      "type": "frame",
      "name": "Colors · HeroUI v3",
      "x": 0,
      "y": 0,
      "layout": "vertical",
      "gap": 24,
      "padding": 32,
      "fill": "$colors:color.background",
      "children": [
        {
          "id": "core-colors-h",
          "type": "text",
          "content": "Colors · HeroUI v3",
          "fill": "$colors:color.foreground",
          "fontFamily": "$type:font.family",
          "fontSize": 24,
          "fontWeight": "700"
        },
        {
          "id": "core-colors-items",
          "type": "frame",
          "name": "Items",
          "layout": "vertical",
          "width": "fit_content",
          "gap": 16,
          "children": [
            {
              "id": "color-swatch",
              "type": "frame",
              "name": "ColorSwatch",
              "width": 40,
              "height": 40,
              "cornerRadius": "$grids:radius.md",
              "fill": "$colors:color.accent",
              "stroke": {
                "thickness": "$grids:border.width",
                "fill": "$colors:color.border"
              },
              "reusable": true,
              "metadata": {
                "type": "component",
                "framework": "heroui",
                "atomic": "atom",
                "fidelity": "full",
                "react": "ColorSwatch",
                "package": "@heroui/react",
                "slug": "color-swatch",
                "category": "Colors"
              }
            },
            {
              "id": "color-field",
              "type": "frame",
              "name": "ColorField",
              "width": 220,
              "height": 40,
              "layout": "horizontal",
              "alignItems": "center",
              "gap": 10,
              "padding": [
                12,
                0
              ],
              "cornerRadius": "$grids:radius.md",
              "fill": "$colors:color.field-background",
              "stroke": {
                "thickness": "$grids:border.width",
                "fill": "$colors:color.border"
