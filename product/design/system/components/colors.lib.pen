              }
            },
            {
              "id": "color-slider",
              "type": "frame",
              "name": "ColorSlider",
              "width": 240,
              "height": 16,
              "layout": "none",
              "children": [
                {
                  "id": "color-slider-bar",
                  "type": "frame",
                  "x": 0,
                  "y": 2,
                  "width": 240,
                  "height": 12,
                  "cornerRadius": 9999,
                  "fill": {
                    "type": "gradient",
                    "gradientType": "linear",
                    "rotation": 90,
                    "colors": [
                      {
                        "color": "#ff0000",
                        "position": 0
                      },
                      {
                        "color": "#00ff00",
                        "position": 0.5
                      },
                      {
                        "color": "#0000ff",
                        "position": 1
                      }
                    ]
                  }
                },
                {
                  "id": "color-slider-thumb",
                  "type": "frame",
                  "x": 150,
                  "y": 0,
                  "width": 16,
                  "height": 16,
                  "cornerRadius": 9999,
                  "fill": "$colors:color.surface",
                  "stroke": {
                    "thickness": 2,
                    "fill": "$colors:color.border"
