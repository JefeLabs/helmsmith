              "alignItems": "center",
              "justifyContent": "space_between",
              "padding": [
                12,
                0
              ],
              "cornerRadius": "$grids:radius.md",
              "fill": "$colors:color.field-background",
              "stroke": {
                "thickness": "$grids:border.width",
                "fill": "$colors:color.border"
              },
              "children": [
                {
                  "id": "date-field-val",
                  "type": "text",
                  "content": "MM / DD / YYYY",
                  "fill": "$colors:color.field-placeholder",
                  "fontFamily": "$type:font.family",
                  "fontSize": "$type:font.size-md"
