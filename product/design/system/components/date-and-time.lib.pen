              "reusable": true,
              "metadata": {
                "type": "component",
                "framework": "heroui",
                "atomic": "molecule",
                "fidelity": "full",
                "react": "DateField",
                "package": "@heroui/react",
                "slug": "date-field",
                "category": "Date and Time"
              }
