                      "children": [
                        {
                          "type": "text",
                          "id": "zhpzF",
                          "name": "mdC1",
                          "fill": "$text-secondary",
                          "content": "const ROTATION_WINDOW = 60 * 60 * 1000   // 1h",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "dTX3A",
                          "name": "mdC2",
                          "fill": "$text-secondary",
                          "content": "return rotateRefresh(token, { window: ROTATION_WINDOW })",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "B72wE7",
                      "name": "mdH2c",
                      "fill": "$text-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "§3 · Token rotation  (regulated-data — FERPA / COPPA)",
                      "fontFamily": "Inter",
                      "fontSize": 16,
