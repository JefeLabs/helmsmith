                      "type": "text",
                      "id": "cSs2G",
                      "name": "mdP1",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Static refresh tokens never rotate; a leaked refresh token grants ~24h of access. ~23% of session-expiry support tickets trace to silent refresh failures (internal data, last quarter).",
                      "lineHeight": 1.55,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "B40UJ",
                      "name": "mdH2b",
                      "fill": "$text-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "§2 · Approach",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "cB4oe",
                      "name": "mdP2",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Replace mintLegacyRefresh with a rotating-token scheme — each refresh issues a new token and invalidates the prior one inside a 1h window. The public /auth API contract is unchanged.",
                      "lineHeight": 1.55,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "RIk8K",
                      "name": "mdCode",
                      "width": "fill_container",
                      "fill": "$bg-primary",
                      "cornerRadius": 6,
