# ─── Discord ──────────────────────────────────────────────────────────
DISCORD_TOKEN=               # bot token from the Developer Portal
GUILD_ID=                    # the server (guild) ID to track

# Text channel IDs (right-click channel → Copy ID; enable Developer Mode)
GOALS_CHANNEL_ID=            # #goals-for-the-day   → start of day
SUMMARY_CHANNEL_ID=          # #summary-of-the-day  → end of day
CI_CHANNEL_ID=               # #ci-cd-notifications → CI submissions (GitHub Monitor)

# Voice channels that count toward engagement (comma-separated). Drives BOTH
# voice-connection time AND text messages in each channel's embedded chat.
VOICE_CHANNEL_IDS=           # e.g. DevOffice,TriageRoom,ProjectOffice,DesignStudio

# Admin gating / reporting
ADMIN_ROLE_ID=               # role allowed to run commands / see reports
REPORT_CHANNEL_ID=           # admin-only channel for pushed summaries
TRACKED_ROLE_ID=             # optional: only track members with this role

# ─── Behaviour ────────────────────────────────────────────────────────
TIMEZONE=America/New_York    # day-boundary timezone for daily/weekly buckets
SCHEDULE_DAILY_AT=09:00      # local HH:MM to push summaries to the report channel
SCHEDULE_FIGMA_SUMMARY=true  # also post a daily Figma activity summary (no-op unless FIGMA_* is set)

# ─── Figma activity tracking (optional — leave blank to disable) ─────
# Runs as a separate process: `timetracker figma start`. See .plan/figma-tracker-prd.md.
FIGMA_TOKEN=                 # personal access token (file_read; +webhooks scope for webhook mode)
FIGMA_TEAM_ID=               # from the team page URL: figma.com/files/team/<TEAM_ID>/…
FIGMA_FILE_KEYS=             # optional seed of tracked file keys (comma-separated); `figma sync-files` discovers more
FIGMA_POLL_INTERVAL_MIN=10   # version/comment poll cadence when webhooks are off

# Webhook mode (Professional+ plan; needs a public HTTPS route to the port):
FIGMA_WEBHOOK_ENABLED=false
FIGMA_WEBHOOK_PORT=3846
FIGMA_WEBHOOK_SECRET=        # delivery passcode — verified on every webhook POST
FIGMA_WEBHOOK_URL=           # public HTTPS route to the port (tunnel/proxy); set → webhooks auto-register

# Burst inference (estimated work sessions from event clustering):
FIGMA_BURST_GAP_MIN=30       # events ≤ this many min apart merge into one burst
FIGMA_BURST_PAD_MIN=15       # padding added to burst start (webhook debounce lag)

# Sentinel presence (real-time in-file presence for monitored files, PRD §4.5):
FIGMA_PRESENCE_ENABLED=false
FIGMA_PRESENCE_POLL_SEC=45   # plugin poll cadence
FIGMA_SENTINEL_USER_ID=      # the sentinel account's Figma user id (filtered from data)
FIGMA_PRESENCE_STALE_SEC=180 # heartbeat age → ⚠ STALE + force-close open intervals

# ─── Storage ──────────────────────────────────────────────────────────
STORAGE_BACKEND=sqlite       # sqlite | dynamodb
SQLITE_PATH=./data/timetracker.db

# Only when STORAGE_BACKEND=dynamodb:
# AWS_REGION=us-east-1
# DDB_TABLE=timetracker
