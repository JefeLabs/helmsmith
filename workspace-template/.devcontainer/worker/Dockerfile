# MVP-1 worker DevContainer template (workspace-template F5).
# Instantiated PER JOB via `@devcontainers/cli up --override-config` —
# NEVER part of docker-compose.yml (workers have independent lifecycles).
#
# Per-job override config (generated by harness-server's spawnWorker):
#   - mounts <workspace>/.harness/run/ → /root/.harness/run/  (UDS to triad)
#   - mounts <workspace>/.harness/wt/<jobId>/<subagent>/<repo>/
#                                    → /workspace/<repo>/    (per-repo worktree)
#   - sets JOB_ID, SUBAGENT_ID, PRODUCT_ID, PIPELINE in containerEnv
#   - labels harness-worker=true + harness-job-id=<id> for reaping
FROM node:22-bookworm-slim

RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

# git for worktree operations from inside; tmux per F30 (read-only attach).
RUN apt-get update && apt-get install -y --no-install-recommends \
      git tmux ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# Stage the harness CLI so agents can call `harness memory|context …` (decision #2).
WORKDIR /opt/agentx
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY tsconfig.base.json tsconfig.json ./

COPY packages/auth-lib/package.json ./packages/auth-lib/
COPY packages/agent-adapter/package.json ./packages/agent-adapter/
COPY packages/edge-memory-server/package.json ./packages/edge-memory-server/
COPY packages/edge-context-server/package.json ./packages/edge-context-server/
COPY packages/harness-cli/package.json ./packages/harness-cli/
COPY packages/harness-server/package.json ./packages/harness-server/

RUN pnpm install --frozen-lockfile --filter @agentx/harness-cli...

COPY packages/auth-lib ./packages/auth-lib
COPY packages/harness-cli ./packages/harness-cli

# Wrapper script so `harness ...` works inside the container.
RUN printf '#!/bin/sh\nexec pnpm --silent --filter @agentx/harness-cli exec tsx /opt/agentx/packages/harness-cli/src/index.ts "$@"\n' > /usr/local/bin/harness \
    && chmod 0755 /usr/local/bin/harness

# Worktrees mount under /workspace/<repoName>/ (per F19 — synthetic monorepo).
WORKDIR /workspace

# tmux session per F30; agentic-worker process replaces this shell in MVP-2+.
RUN echo "set -g mouse on\nset -g history-limit 50000" > /root/.tmux.conf

ENTRYPOINT ["sh", "-c", "tmux new-session -d -s agent-${JOB_ID:-noname} && exec tail -f /dev/null"]
