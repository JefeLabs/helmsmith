{
  "name": "agentx-worker-template",
  // Reference the pre-built worker image rather than rebuilding per
  // workspace. `workspace start` (or `workspace build-worker`) builds
  // and tags this image once on the host; all workspaces' devcontainers
  // reuse it. Faster cold-start; trade-off is the user must run
  // `workspace start` (or build-worker) once before submitting jobs.
  //
  // For local-customization (extra apt packages etc.), users can switch
  // back to a `build` block referencing this image as the base via FROM
  // agentx/worker:dev in a workspace-local Dockerfile.
  "image": "agentx/worker:dev",
  "workspaceFolder": "/workspace",
  "overrideCommand": false,
  "shutdownAction": "none"
}
